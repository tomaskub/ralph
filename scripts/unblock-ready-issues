#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
import re
import subprocess
from dataclasses import dataclass
from typing import Any


DEFAULT_OWNER = "tomaskub"
DEFAULT_REPO = "tomaskub/ralph"
DEFAULT_PROJECT_NUMBER = 2
DEFAULT_PROJECT_ID = "PVT_kwHOAHb4Cc4Ba3EA"
DEFAULT_BACKLOG_STATUS = "Backlog"
DEFAULT_READY_STATUS = "Ready"
DEFAULT_READY_LABEL = "ready-for-agent"


@dataclass(frozen=True)
class Issue:
    number: int
    title: str
    body: str
    state: str
    labels: frozenset[str]


@dataclass(frozen=True)
class ProjectItem:
    issue_number: int
    item_id: str
    status: str | None


def run_gh(args: list[str]) -> Any:
    completed = subprocess.run(
        ["gh", *args],
        check=True,
        stdout=subprocess.PIPE,
        text=True,
    )
    output = completed.stdout.strip()
    if not output:
        return None
    return json.loads(output)


def run_graphql(query: str, variables: dict[str, str]) -> Any:
    args = ["api", "graphql", "-f", f"query={query}"]
    for key, value in variables.items():
        args.extend(["-f", f"{key}={value}"])
    return run_gh(args)


def blocked_by_issue_numbers(body: str) -> set[int]:
    match = re.search(
        r"^## Blocked by\s*\n(?P<section>.*?)(?=^##\s|\Z)",
        body or "",
        flags=re.IGNORECASE | re.MULTILINE | re.DOTALL,
    )
    if not match:
        return set()

    section = match.group("section")
    if re.search(r"\bnone\b", section, flags=re.IGNORECASE):
        return set()

    numbers = {int(number) for number in re.findall(r"(?<![\w/])#(\d+)\b", section)}
    numbers.update(
        int(number)
        for number in re.findall(
            r"https://github\.com/[^/\s]+/[^/\s]+/issues/(\d+)\b",
            section,
            flags=re.IGNORECASE,
        )
    )
    return numbers


def load_open_issues(repo: str) -> dict[int, Issue]:
    raw_issues = run_gh(
        [
            "issue",
            "list",
            "--repo",
            repo,
            "--state",
            "open",
            "--limit",
            "1000",
            "--json",
            "number,title,body,state,labels",
        ]
    )
    return {
        issue["number"]: Issue(
            number=issue["number"],
            title=issue["title"],
            body=issue.get("body") or "",
            state=issue["state"],
            labels=frozenset(label["name"] for label in issue.get("labels", [])),
        )
        for issue in raw_issues
    }


def load_closed_issue_numbers(repo: str) -> set[int]:
    raw_issues = run_gh(
        [
            "issue",
            "list",
            "--repo",
            repo,
            "--state",
            "closed",
            "--limit",
            "1000",
            "--json",
            "number",
        ]
    )
    return {issue["number"] for issue in raw_issues}


def project_items_from_graphql(payload: dict[str, Any], repo: str) -> dict[int, ProjectItem]:
    project = payload["data"]["node"]
    items: dict[int, ProjectItem] = {}
    for item in project["items"]["nodes"]:
        content = item.get("content") or {}
        repository = content.get("repository") or {}
        if content.get("__typename") != "Issue" or repository.get("nameWithOwner") != repo:
            continue

        status = None
        for field_value in item["fieldValues"]["nodes"]:
            field = field_value.get("field") or {}
            if (
                field_value.get("__typename") == "ProjectV2ItemFieldSingleSelectValue"
                and field.get("name") == "Status"
            ):
                status = field_value["name"]
                break

        items[content["number"]] = ProjectItem(
            issue_number=content["number"],
            item_id=item["id"],
            status=status,
        )
    return items


def load_project_items(repo: str, project_id: str) -> dict[int, ProjectItem]:
    query = """
query($projectId: ID!) {
  node(id: $projectId) {
    ... on ProjectV2 {
      items(first: 100) {
        nodes {
          id
          content {
            __typename
            ... on Issue {
              number
              repository {
                nameWithOwner
              }
            }
          }
          fieldValues(first: 20) {
            nodes {
              __typename
              ... on ProjectV2ItemFieldSingleSelectValue {
                name
                field {
                  ... on ProjectV2SingleSelectField {
                    name
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
"""
    return project_items_from_graphql(
        run_graphql(query, {"projectId": project_id}),
        repo=repo,
    )


def status_metadata_from_graphql(
    payload: dict[str, Any],
    project_id: str,
    ready_status: str,
) -> tuple[str, str, str]:
    project = payload["data"]["node"]
    for field in project["fields"]["nodes"]:
        if field.get("__typename") != "ProjectV2SingleSelectField":
            continue
        if field.get("name") != "Status":
            continue
        for option in field.get("options", []):
            if option["name"] == ready_status:
                return project_id, field["id"], option["id"]
        msg = f"Project Status field has no {ready_status!r} option"
        raise SystemExit(msg)

    raise SystemExit("Project has no Status field")


def load_project_status_metadata(
    project_id: str,
    ready_status: str,
) -> tuple[str, str, str]:
    query = """
query($projectId: ID!) {
  node(id: $projectId) {
    ... on ProjectV2 {
      fields(first: 50) {
        nodes {
          __typename
          ... on ProjectV2SingleSelectField {
            id
            name
            options {
              id
              name
            }
          }
        }
      }
    }
  }
}
"""
    return status_metadata_from_graphql(
        run_graphql(query, {"projectId": project_id}),
        project_id=project_id,
        ready_status=ready_status,
    )


def dependency_is_done(issue_number: int, closed_issue_numbers: set[int]) -> bool:
    return issue_number in closed_issue_numbers


def ready_candidates(
    open_issues: dict[int, Issue],
    closed_issue_numbers: set[int],
    project_items: dict[int, ProjectItem],
    backlog_status: str,
) -> list[Issue]:
    candidates: list[Issue] = []
    for issue in open_issues.values():
        item = project_items.get(issue.number)
        if item is None or item.status != backlog_status:
            continue

        blockers = blocked_by_issue_numbers(issue.body)
        if not blockers:
            continue

        if all(dependency_is_done(blocker, closed_issue_numbers) for blocker in blockers):
            candidates.append(issue)

    return candidates


def move_issue_to_ready(
    issue: Issue,
    repo: str,
    project_id: str,
    project_item_id: str,
    status_field_id: str,
    ready_option_id: str,
    ready_label: str,
    dry_run: bool,
) -> None:
    print(f"#{issue.number} {issue.title}")
    if dry_run:
        print("  would add label and move project item to Ready")
        return

    if ready_label not in issue.labels:
        run_gh(["issue", "edit", str(issue.number), "--repo", repo, "--add-label", ready_label])

    query = """
mutation(
  $projectId: ID!
  $itemId: ID!
  $fieldId: ID!
  $optionId: String!
) {
  updateProjectV2ItemFieldValue(
    input: {
      projectId: $projectId
      itemId: $itemId
      fieldId: $fieldId
      value: { singleSelectOptionId: $optionId }
    }
  ) {
    projectV2Item {
      id
    }
  }
}
"""
    run_graphql(
        query,
        {
            "projectId": project_id,
            "itemId": project_item_id,
            "fieldId": status_field_id,
            "optionId": ready_option_id,
        },
    )
    print("  moved to Ready")


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description=(
            "Move Backlog issues to Ready when every issue in their "
            "'## Blocked by' section is closed."
        )
    )
    parser.add_argument("--owner", default=DEFAULT_OWNER)
    parser.add_argument("--repo", default=DEFAULT_REPO)
    parser.add_argument("--project-number", type=int, default=DEFAULT_PROJECT_NUMBER)
    parser.add_argument("--project-id", default=DEFAULT_PROJECT_ID)
    parser.add_argument("--backlog-status", default=DEFAULT_BACKLOG_STATUS)
    parser.add_argument("--ready-status", default=DEFAULT_READY_STATUS)
    parser.add_argument("--ready-label", default=DEFAULT_READY_LABEL)
    parser.add_argument("--dry-run", action="store_true")
    return parser.parse_args()


def main() -> None:
    args = parse_args()
    open_issues = load_open_issues(args.repo)
    closed_issue_numbers = load_closed_issue_numbers(args.repo)
    project_items = load_project_items(args.repo, args.project_id)
    candidates = ready_candidates(
        open_issues=open_issues,
        closed_issue_numbers=closed_issue_numbers,
        project_items=project_items,
        backlog_status=args.backlog_status,
    )

    if not candidates:
        print("No blocked Backlog issues are ready.")
        return

    project_id, status_field_id, ready_option_id = load_project_status_metadata(
        project_id=args.project_id,
        ready_status=args.ready_status,
    )
    for issue in candidates:
        project_item_id = project_items[issue.number].item_id
        move_issue_to_ready(
            issue=issue,
            repo=args.repo,
            project_id=project_id,
            project_item_id=project_item_id,
            status_field_id=status_field_id,
            ready_option_id=ready_option_id,
            ready_label=args.ready_label,
            dry_run=args.dry_run,
        )


if __name__ == "__main__":
    main()
