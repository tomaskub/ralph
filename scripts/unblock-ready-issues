#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
import re
import subprocess
from dataclasses import dataclass
from typing import Any


DEFAULT_OWNER = "tomaskub"
DEFAULT_REPO = "tomaskub/ralph"
DEFAULT_PROJECT_NUMBER = 2
DEFAULT_BACKLOG_STATUS = "Backlog"
DEFAULT_READY_STATUS = "Ready"
DEFAULT_READY_LABEL = "ready-for-agent"


@dataclass(frozen=True)
class Issue:
    number: int
    title: str
    body: str
    state: str
    labels: frozenset[str]


@dataclass(frozen=True)
class ProjectItem:
    issue_number: int
    item_id: str
    status: str | None


def run_gh(args: list[str]) -> Any:
    completed = subprocess.run(
        ["gh", *args],
        check=True,
        stdout=subprocess.PIPE,
        text=True,
    )
    output = completed.stdout.strip()
    if not output:
        return None
    return json.loads(output)


def blocked_by_issue_numbers(body: str) -> set[int]:
    match = re.search(
        r"^## Blocked by\s*\n(?P<section>.*?)(?=^##\s|\Z)",
        body or "",
        flags=re.IGNORECASE | re.MULTILINE | re.DOTALL,
    )
    if not match:
        return set()

    section = match.group("section")
    if re.search(r"\bnone\b", section, flags=re.IGNORECASE):
        return set()

    numbers = {int(number) for number in re.findall(r"(?<![\w/])#(\d+)\b", section)}
    numbers.update(
        int(number)
        for number in re.findall(
            r"https://github\.com/[^/\s]+/[^/\s]+/issues/(\d+)\b",
            section,
            flags=re.IGNORECASE,
        )
    )
    return numbers


def load_open_issues(repo: str) -> dict[int, Issue]:
    raw_issues = run_gh(
        [
            "issue",
            "list",
            "--repo",
            repo,
            "--state",
            "open",
            "--limit",
            "1000",
            "--json",
            "number,title,body,state,labels",
        ]
    )
    return {
        issue["number"]: Issue(
            number=issue["number"],
            title=issue["title"],
            body=issue.get("body") or "",
            state=issue["state"],
            labels=frozenset(label["name"] for label in issue.get("labels", [])),
        )
        for issue in raw_issues
    }


def load_closed_issue_numbers(repo: str) -> set[int]:
    raw_issues = run_gh(
        [
            "issue",
            "list",
            "--repo",
            repo,
            "--state",
            "closed",
            "--limit",
            "1000",
            "--json",
            "number",
        ]
    )
    return {issue["number"] for issue in raw_issues}


def load_project_items(owner: str, project_number: int) -> dict[int, ProjectItem]:
    raw_items = run_gh(
        [
            "project",
            "item-list",
            str(project_number),
            "--owner",
            owner,
            "--format",
            "json",
            "--limit",
            "1000",
        ]
    )

    items: dict[int, ProjectItem] = {}
    for item in raw_items["items"]:
        content = item.get("content") or {}
        if content.get("type") != "Issue" or "number" not in content:
            continue
        items[content["number"]] = ProjectItem(
            issue_number=content["number"],
            item_id=item["id"],
            status=item.get("status"),
        )
    return items


def load_project_status_metadata(
    owner: str,
    project_number: int,
    ready_status: str,
) -> tuple[str, str, str]:
    project = run_gh(
        [
            "project",
            "view",
            str(project_number),
            "--owner",
            owner,
            "--format",
            "json",
        ]
    )
    fields = run_gh(
        [
            "project",
            "field-list",
            str(project_number),
            "--owner",
            owner,
            "--format",
            "json",
        ]
    )

    for field in fields["fields"]:
        if field["name"] != "Status":
            continue
        for option in field.get("options", []):
            if option["name"] == ready_status:
                return project["id"], field["id"], option["id"]
        msg = f"Project Status field has no {ready_status!r} option"
        raise SystemExit(msg)

    raise SystemExit("Project has no Status field")


def dependency_is_done(issue_number: int, closed_issue_numbers: set[int]) -> bool:
    return issue_number in closed_issue_numbers


def ready_candidates(
    open_issues: dict[int, Issue],
    closed_issue_numbers: set[int],
    project_items: dict[int, ProjectItem],
    backlog_status: str,
) -> list[Issue]:
    candidates: list[Issue] = []
    for issue in open_issues.values():
        item = project_items.get(issue.number)
        if item is None or item.status != backlog_status:
            continue

        blockers = blocked_by_issue_numbers(issue.body)
        if not blockers:
            continue

        if all(dependency_is_done(blocker, closed_issue_numbers) for blocker in blockers):
            candidates.append(issue)

    return candidates


def move_issue_to_ready(
    issue: Issue,
    repo: str,
    project_id: str,
    project_item_id: str,
    status_field_id: str,
    ready_option_id: str,
    ready_label: str,
    dry_run: bool,
) -> None:
    print(f"#{issue.number} {issue.title}")
    if dry_run:
        print("  would add label and move project item to Ready")
        return

    if ready_label not in issue.labels:
        run_gh(["issue", "edit", str(issue.number), "--repo", repo, "--add-label", ready_label])

    run_gh(
        [
            "project",
            "item-edit",
            "--id",
            project_item_id,
            "--project-id",
            project_id,
            "--field-id",
            status_field_id,
            "--single-select-option-id",
            ready_option_id,
        ]
    )
    print("  moved to Ready")


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description=(
            "Move Backlog issues to Ready when every issue in their "
            "'## Blocked by' section is closed."
        )
    )
    parser.add_argument("--owner", default=DEFAULT_OWNER)
    parser.add_argument("--repo", default=DEFAULT_REPO)
    parser.add_argument("--project-number", type=int, default=DEFAULT_PROJECT_NUMBER)
    parser.add_argument("--backlog-status", default=DEFAULT_BACKLOG_STATUS)
    parser.add_argument("--ready-status", default=DEFAULT_READY_STATUS)
    parser.add_argument("--ready-label", default=DEFAULT_READY_LABEL)
    parser.add_argument("--dry-run", action="store_true")
    return parser.parse_args()


def main() -> None:
    args = parse_args()
    open_issues = load_open_issues(args.repo)
    closed_issue_numbers = load_closed_issue_numbers(args.repo)
    project_items = load_project_items(args.owner, args.project_number)
    candidates = ready_candidates(
        open_issues=open_issues,
        closed_issue_numbers=closed_issue_numbers,
        project_items=project_items,
        backlog_status=args.backlog_status,
    )

    if not candidates:
        print("No blocked Backlog issues are ready.")
        return

    project_id, status_field_id, ready_option_id = load_project_status_metadata(
        owner=args.owner,
        project_number=args.project_number,
        ready_status=args.ready_status,
    )
    for issue in candidates:
        project_item_id = project_items[issue.number].item_id
        move_issue_to_ready(
            issue=issue,
            repo=args.repo,
            project_id=project_id,
            project_item_id=project_item_id,
            status_field_id=status_field_id,
            ready_option_id=ready_option_id,
            ready_label=args.ready_label,
            dry_run=args.dry_run,
        )


if __name__ == "__main__":
    main()
